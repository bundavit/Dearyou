APP_NAME=DearYou
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dearyous.app

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dearyou
DB_USERNAME=dearyou
DB_PASSWORD="replace-with-a-long-random-password"

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD="replace-with-a-unique-admin-password"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

# Use a transactional email provider before opening public registration.
# Copy the exact SMTP values supplied by your provider.
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-username
MAIL_PASSWORD="replace-with-smtp-password"
MAIL_TIMEOUT=15
MAIL_FROM_ADDRESS=hello@dearyous.app
MAIL_FROM_NAME="${APP_NAME}"
